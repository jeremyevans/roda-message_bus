source 'https://rubygems.org'

gem "rake"
gem "minitest-global_expectations"

if RUBY_VERSION >= "3.4"
  gem 'logger'
end

if RUBY_VERSION >= '2'
  gem "roda"
  gem "message_bus"
  gem 'json'
else
  gem "roda", '2.0.0'
  gem "message_bus", '2.0.0'
  gem 'json', '<1.8.5'
end

if RUBY_VERSION < '2.6' && RUBY_VERSION >= '2.4'
  gem 'rack', '= 3.2.5'
end
